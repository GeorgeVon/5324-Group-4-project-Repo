<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_page_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark_green" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/home_page_subtitle"
            android:textSize="16sp"
            android:textColor="@color/text_grey" />

        <CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:weekSeparatorLineColor="@color/primary_green"
            android:selectedWeekBackgroundColor="@color/primary_green" />

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/selected_date_label"
            android:textSize="16sp"
            android:textColor="@color/primary_dark_green" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddEvent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/add_event_button"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary_green" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddTask"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/add_task_button"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary_dark_green" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/schedule_header"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark_green" />

        <TextView
            android:id="@+id/tvScheduleEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/no_schedule_items"
            android:textColor="@color/text_grey"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/scheduleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="@color/primary_green" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/speak_task_section_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark_green" />

        <EditText
            android:id="@+id/editTaskText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/home_page_task_hint"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:padding="12dp"
            android:background="?android:attr/editTextBackground" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSpeakTask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/speak_task_button"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary_green" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopSpeech"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/stop_speech_button"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary_dark_green" />
    </LinearLayout>
</ScrollView>
